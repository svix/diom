{% from "types/macros.ts.jinja" import field_from_json, field_to_json -%}
{% for c in referenced_components -%}
import {
    type {{ c | to_upper_camel_case }},
    {{ c | to_upper_camel_case }}Serializer,
} from './{{ c | to_lower_camel_case }}';
{% endfor -%}
{% set type_name = type.name | to_upper_camel_case -%}
{% set positional_fields = type.fields | selectattr("positional") -%}

{% if type.fields | selectattr("positional", "false") | length == 0 -%}
// biome-ignore-all lint/suspicious/noEmptyInterface: forwards compat
{% endif -%}

{{ doc_comment }}
export interface {{ type_name }} {
{%- for field in type.fields %}
    {%- if not field.positional %}
    {% if field.description is defined -%}
        {{ field.description | with_javadoc_deprecation(field.deprecated) | to_doc_comment(style="js") | indent(5) }}
    {% endif -%}
    {% set field_lhs = field.name | to_lower_camel_case -%}
    {% if not field.required %}{% set field_lhs %}{{ field_lhs }}?{% endset %}{% endif -%}
    {% set ty = field.type.to_js() -%}
    {% if field.nullable %}{% set ty %}{{ ty }} | null{% endset %}{% endif -%}
    {{ field_lhs }}: {{ ty }};
    {%- endif %}
{%- endfor %}
}

{% if positional_fields | length > 0 -%}
export interface {{ type_name }}_ {
    {%- include "types/struct_fields.ts.jinja" %}
}

{% endif -%}

export const {{ type_name }}Serializer = {
    {% if positional_fields | length > 0 %}{% set type_name = type_name ~ "_" %}{% endif -%}
    {% set underscore_prefix %}{% if type.fields | length == 0%}_{% endif %}{% endset -%}
    // biome-ignore lint/suspicious/noExplicitAny: intentional any
    _fromJsonObject({{ underscore_prefix }}object: any): {{ type_name }} {
        return {
        {%- for field in type.fields %}
            {% set field_expr %}object['{{ field.name }}']{% endset -%}
            {{ field.name | to_lower_camel_case }}: {{ field_from_json(field_expr, field.type, field.required) }},
        {%- endfor %}
        };
    },

    // biome-ignore lint/suspicious/noExplicitAny: intentional any
    _toJsonObject({{ underscore_prefix }}self: {{ type_name }}): any {
        return {
        {%- for field in type.fields %}
            {% set field_expr %}self.{{ field.name | to_lower_camel_case }}{% endset -%}
            '{{ field.name }}': {{ field_to_json(field_expr, field.type, field.required) }},
        {%- endfor %}
        };
    }
}
