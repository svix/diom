// @ts-nocheck
// this file is @generated
{% set resource_type_name = resource.name | to_upper_camel_case -%}

{%- set ns = namespace(needs_byte_string=false, needs_raw_json=false, needs_wire_json=false, serializer_imports=[]) -%}
{%- for op in resource.operations -%}
  {%- if op.request_body_schema_name is defined -%}
    {%- set ns.needs_raw_json = true -%}
    {%- set body_schema_tmp = api.types[op.request_body_schema_name] -%}
    {%- for field in body_schema_tmp.fields | selectattr("positional") -%}
      {%- if field.type.is_bytes() -%}
        {%- set ns.needs_byte_string = true -%}
      {%- endif -%}
    {%- endfor -%}
    {%- set ns.serializer_imports = ns.serializer_imports + [op.request_body_schema_name | to_upper_camel_case ~ "Serializer"] -%}
  {%- endif -%}
  {%- if op.response_body_schema_name is defined -%}
    {%- set ns.needs_wire_json = true -%}
    {%- set ns.serializer_imports = ns.serializer_imports + [op.response_body_schema_name | to_upper_camel_case ~ "Serializer"] -%}
  {%- endif -%}
{%- endfor %}

import type { Argv } from "yargs";
{% if ns.needs_byte_string -%}
import { parseByteString } from "../byte-string.ts";
{% endif -%}
import type { IoContext } from "../io.ts";
{% if ns.needs_raw_json -%}
import { readJsonArg } from "../json-arg.ts";
{% endif -%}
{% if ns.needs_wire_json -%}
import { printWireJson } from "../print-json.ts";
{% endif -%}
{% if ns.serializer_imports | unique | list | length > 0 -%}
import { {{ ns.serializer_imports | unique | join(", ") }} } from "@diomhq/diom";
{% endif -%}
{% for _, sub in resource.subresources | items -%}
import { register{{ sub.name | to_upper_camel_case }}Commands } from "./{{ sub.name | to_lower_camel_case }}.ts";
{% endfor %}
{%- macro plain_schema_example(title, schema) %}
{{ title }}:
{
{%- for field in schema.fields | selectattr("positional", "false") %}
  "{{ field.name }}": "{{ field.example if field.example is defined else '...' }}"{{ "," if not loop.last else "" }}
{%- endfor %}
}
{%- endmacro %}

{%- macro diom_chain(resource) -%}
{%- for segment in resource.name | split(".") -%}
.{{ segment | to_lower_camel_case }}
{%- endfor -%}
{%- endmacro %}

/**
 * Register CLI commands for this API resource (nested yargs commands; same shape as the Rust diom-cli).
 */
export function register{{ resource_type_name }}Commands(
  y: Argv,
  io: IoContext,
): Argv {
  {% for name, sub in resource.subresources | items -%}
  y.command(
    "{{ name | replace('_', '-') }}",
    "",
    (y2) => {
      register{{ sub.name | to_upper_camel_case }}Commands(y2, io);
      return y2.demandCommand(1).strict();
    },
  );
  {% endfor %}

  {% for op in resource.operations -%}
  {% if op.request_body_schema_name is defined -%}
  {% set body_schema = api.types[op.request_body_schema_name] -%}
  {% set positional_fields = body_schema.fields | selectattr("positional") -%}
  {% set body_schema_all_optional = body_schema.fields
      | selectattr("required")
      | selectattr("positional", "false")
      | length == 0 %}
  {% set usage -%}
{{ op.name | replace("_", "-") }}{% for field in positional_fields %} <{{ field.name | replace("_", "-") }}>{% endfor %}{% if body_schema_all_optional %} [body]{% else %} <body>{% endif %}
  {%- endset %}
  {% set body_serializer = op.request_body_schema_name | to_upper_camel_case ~ "Serializer" -%}
  y.command(
    `{{ usage | trim }}`,
    `{% if op.deprecated %}[deprecated] {% endif %}{{ op.description | default("", true) | replace("`", "'") }}`,
    (cmdY) => {
      {%- if op.request_body_schema_name is defined or op.response_body_schema_name is defined %}
      cmdY.epilog(
        [
          {%- if op.request_body_schema_name is defined %}
          `{{ plain_schema_example("Example body", api.types[op.request_body_schema_name]) | trim | replace("`", "'") }}`,
          {%- endif %}
          {%- if op.request_body_schema_name is defined and op.response_body_schema_name is defined %}
          "",
          {%- endif %}
          {%- if op.response_body_schema_name is defined %}
          `{{ plain_schema_example("Example response", api.types[op.response_body_schema_name]) | trim | replace("`", "'") }}`,
          {%- endif %}
        ].join("\n"),
      );
      {%- endif %}
      return cmdY;
    },
    async (argv) => {
      const client = io.diom;
      {%- for field in positional_fields %}
      {% if field.type.is_bytes() %}
      const {{ field.name | to_lower_camel_case }} = parseByteString(
        String(argv["{{ field.name | replace('_', '-') }}"]),
      );
      {% else %}
      const {{ field.name | to_lower_camel_case }} = String(
        argv["{{ field.name | replace('_', '-') }}"],
      );
      {% endif %}
      {%- endfor %}
      {% set body_param = op.request_body_schema_name | to_lower_camel_case %}
      {% if body_schema_all_optional %}
      const bodyRaw = argv.body as string | undefined;
      const {{ body_param }} =
        bodyRaw === undefined
          ? {}
          : {{ body_serializer }}._fromJsonObject(await readJsonArg(bodyRaw, io.readStdin));
      {% else %}
      const {{ body_param }} = {{ body_serializer }}._fromJsonObject(
        await readJsonArg(String(argv.body), io.readStdin),
      );
      {% endif %}
      {%- if op.response_body_schema_name is defined %}
      {% set resp_serializer = op.response_body_schema_name | to_upper_camel_case ~ "Serializer" -%}
      const resp = await client{{ diom_chain(resource) }}.{{ op.name | to_lower_camel_case }}(
        {% for field in positional_fields -%}
        {{ field.name | to_lower_camel_case }},
        {% endfor -%}
        {{ body_param }},
      );
      printWireJson({{ resp_serializer }}._toJsonObject(resp));
      {%- else %}
      await client{{ diom_chain(resource) }}.{{ op.name | to_lower_camel_case }}(
        {% for field in positional_fields -%}
        {{ field.name | to_lower_camel_case }},
        {% endfor -%}
        {{ body_param }},
      );
      {%- endif %}
    },
  );
  {% else %}
  y.command(
    "{{ op.name | replace('_', '-') }}",
    `{% if op.deprecated %}[deprecated] {% endif %}{{ op.description | default("", true) | replace("`", "'") }}`,
    (cmdY) => {
      {%- if op.response_body_schema_name is defined %}
      cmdY.epilog(
        `{{ plain_schema_example("Example response", api.types[op.response_body_schema_name]) | trim | replace("`", "'") }}`,
      );
      {%- endif %}
      return cmdY;
    },
    async (_argv) => {
      const client = io.diom;
      {%- if op.response_body_schema_name is defined %}
      {% set resp_serializer = op.response_body_schema_name | to_upper_camel_case ~ "Serializer" -%}
      const resp = await client{{ diom_chain(resource) }}.{{ op.name | to_lower_camel_case }}();
      printWireJson({{ resp_serializer }}._toJsonObject(resp));
      {%- else %}
      await client{{ diom_chain(resource) }}.{{ op.name | to_lower_camel_case }}();
      {%- endif %}
    },
  );
  {% endif %}
  {% endfor %}

  return y.demandCommand(1).strict();
}
