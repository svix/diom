resource "datadog_monitor" "redis_cpu_utilization" {
  name    = "${var.env} redis high cpu utilization"
  type    = "metric alert"
  message = <<EOH
{{#is_alert}}
@pagerduty-${var.pagerduty_service} ${var.env} redis high cpu utilization
{{/is_alert}}

{{#is_recovery}}
@pagerduty-${var.pagerduty_service}
{{/is_recovery}}

  EOH

  escalation_message = "Escalation ${var.env} redis high cpu utilization"

  query = "avg(last_5m):aws.memorydb.cpuutilization{env:${var.env}} > 47"

  monitor_thresholds {
    ok       = 0
    warning  = 40
    critical = 47
  }

  include_tags = true

}

resource "datadog_monitor" "lb_latency" {
  name    = "${var.env} LB latency"
  type    = "metric alert"
  message = <<EOH
{{#is_alert}}
@pagerduty-${var.pagerduty_service} ${var.env} LB latency
{{/is_alert}}

{{#is_recovery}}
@pagerduty-${var.pagerduty_service}
{{/is_recovery}}

  EOH

  escalation_message = "Escalation ${var.env} LB latency"

  query = "avg(last_5m):avg:aws.applicationelb.target_response_time.average{env:${var.env}} > 500"

  monitor_thresholds {
    ok       = 0
    warning  = 250
    critical = 500
  }

  include_tags = true

}

resource "datadog_monitor" "lb_unhealthy_hosts" {
  name    = "${var.env} LB unhealthy host count"
  type    = "metric alert"
  message = <<EOH
{{#is_alert}}
@pagerduty-${var.pagerduty_service} ${var.env} LB unhealthy host count
{{/is_alert}}

{{#is_recovery}}
@pagerduty-${var.pagerduty_service}
{{/is_recovery}}

  EOH

  escalation_message = "Escalation ${var.env} LB unhealthy host count"

  query = "max(last_5m):max:aws.applicationelb.un_healthy_host_count{env:${var.env}} >= 1"

  monitor_thresholds {
    critical = 1
  }

  include_tags = true

}
