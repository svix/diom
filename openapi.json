  "components": {
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "HTTP Bearer token passed in the `Authorization` header"
      }
    },
    "schemas": {
      "PingOut": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "CacheSetIn": {
        "type": "object",
        "required": [
          "expires_at",
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "expires_at": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "value": {
            "type": "string"
          }
        }
      },
      "CacheSetOut": {
        "type": "object"
      },
      "CacheGetIn": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        }
      },
      "CacheGetOut": {
        "type": "object",
        "required": [
          "expires_at",
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
