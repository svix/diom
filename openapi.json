  "components": {
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "HTTP Bearer token passed in the `Authorization` header"
      }
    },
    "schemas": {
      "AckIn": {
        "type": "object",
        "properties": {
          "consumerGroup": {
            "type": "string"
          },
          "maxMsgId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "minMsgId": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0,
            "nullable": true
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "consumerGroup",
          "maxMsgId"
        ]
      },
      "AckOut": {
        "type": "object"
      },
      "AppendToStreamIn": {
        "type": "object",
        "properties": {
          "msgs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MsgIn"
            }
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "msgs"
        ]
      },
      "AppendToStreamOut": {
        "type": "object",
        "properties": {
          "msgIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            }
          }
        },
        "required": [
          "msgIds"
        ]
      },
      "CacheDeleteIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "example": "some_key",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$"
          }
        },
        "required": [
          "key"
        ]
      },
      "CacheDeleteOut": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean"
          }
        },
        "required": [
          "deleted"
        ]
      },
      "CacheGetIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "example": "some_key",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$"
          }
        },
        "required": [
          "key"
        ]
      },
      "CacheGetOut": {
        "type": "object",
        "properties": {
          "expires_at": {
            "description": "Time of expiry",
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "key": {
            "type": "string",
            "example": "some_key",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$"
          },
          "value": {
            "type": "string"
          }
        },
        "required": [
          "key",
          "value"
        ]
      },
      "CacheSetIn": {
        "type": "object",
        "properties": {
          "expire_in": {
            "description": "Time to live in milliseconds",
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "key": {
            "type": "string",
            "example": "some_key",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$"
          },
          "value": {
            "type": "string"
          }
        },
