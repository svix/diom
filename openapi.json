  "components": {
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "HTTP Bearer token passed in the `Authorization` header"
      }
    },
    "schemas": {
      "CacheDeleteIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        },
        "required": [
          "key"
        ]
      },
      "CacheDeleteOut": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean"
          }
        },
        "required": [
          "deleted"
        ]
      },
      "CacheGetIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        },
        "required": [
          "key"
        ],
        "x-positional": [
          "key"
        ]
      },
      "CacheGetNamespaceIn": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "CacheGetNamespaceOut": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "max_storage_bytes": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "nullable": true
          },
          "storage_type": {
            "$ref": "#/components/schemas/StorageType"
          },
          "eviction_policy": {
            "$ref": "#/components/schemas/EvictionPolicy"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "storage_type",
          "eviction_policy",
          "created_at",
          "updated_at"
        ]
      },
      "CacheGetOut": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "expiry": {
            "description": "Time of expiry",
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "value": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0,
              "maximum": 255
            }
          }
        },
        "required": [
          "key",
          "value"
        ]
      },
      "CacheSetIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "ttl": {
            "description": "Time to live in milliseconds",
            "type": "integer",
            "format": "uint64",
            "minimum": 0
          },
          "value": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0,
              "maximum": 255
            }
          }
        },
        "required": [
          "key",
          "ttl",
          "value"
        ],
        "x-positional": [
          "key",
          "value"
        ]
      },
      "CacheSetOut": {
        "type": "object"
      },
      "CreateNamespaceIn": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "retention": {
            "default": {
              "millis": 2592000000,
              "bytes": 1000000000000
            },
            "$ref": "#/components/schemas/Retention"
          },
          "storage_type": {
            "default": "Persistent",
            "$ref": "#/components/schemas/StorageType"
          }
        },
        "required": [
          "name"
        ]
      },
      "CreateNamespaceOut": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "retention": {
            "$ref": "#/components/schemas/Retention"
          },
          "storage_type": {
            "$ref": "#/components/schemas/StorageType"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "retention",
          "storage_type",
          "created",
          "updated"
        ]
      },
      "EvictionPolicy": {
        "type": "string",
        "enum": [
          "NoEviction",
          "LeastRecentlyUsed"
        ]
      },
      "GetNamespaceIn": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "GetNamespaceOut": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "retention": {
            "$ref": "#/components/schemas/Retention"
          },
          "storage_type": {
            "$ref": "#/components/schemas/StorageType"
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "updated": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "retention",
          "storage_type",
          "created",
          "updated"
        ]
      },
      "IdempotencyAbortIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        },
        "required": [
          "key"
        ]
      },
      "IdempotencyAbortOut": {
        "type": "object"
      },
      "IdempotencyCompleteIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "response": {
            "description": "The response to cache",
            "type": "array",
            "items": {
              "type": "integer",
              "format": "uint8",
              "minimum": 0,
              "maximum": 255
            }
          },
          "ttl": {
            "description": "TTL in seconds for the cached response",
            "type": "integer",
            "format": "uint64",
            "minimum": 1
          }
        },
        "required": [
          "key",
          "response",
          "ttl"
        ]
      },
      "IdempotencyCompleteOut": {
        "type": "object"
      },
      "IdempotencyGetNamespaceIn": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      },
      "IdempotencyGetNamespaceOut": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "max_storage_bytes": {
            "type": "integer",
            "format": "uint64",
            "minimum": 1,
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "created_at",
          "updated_at"
        ]
      },
      "IdempotencyStartIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "ttl": {
            "description": "TTL in seconds for the lock/response",
            "type": "integer",
            "format": "uint64",
            "minimum": 1
          }
        },
        "required": [
