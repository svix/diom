  "components": {
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "HTTP Bearer token passed in the `Authorization` header"
      }
    },
    "schemas": {
      "CacheDeleteIn": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "example": "some_key",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$"
          }
        },
        "required": [
          "key"
        ]
      },
      "CacheDeleteOut": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean"
          }
