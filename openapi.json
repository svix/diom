  "components": {
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer",
        "description": "HTTP Bearer token passed in the `Authorization` header"
      }
    },
    "schemas": {
      "PingOut": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "CacheSetIn": {
        "type": "object",
        "required": [
          "expires_at",
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "expires_at": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "value": {
            "type": "string"
          }
        }
      },
      "CacheSetOut": {
        "type": "object"
      },
      "CacheGetIn": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        }
      },
      "CacheGetOut": {
        "type": "object",
        "required": [
          "expires_at",
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "expires_at": {
            "description": "Time of expiry",
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "value": {
            "type": "string"
          }
        }
      },
      "CacheDeleteIn": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        }
      },
      "CacheDeleteOut": {
        "type": "object",
        "required": [
          "deleted"
        ],
        "properties": {
          "deleted": {
            "type": "boolean"
          }
        }
      },
      "KvSetIn": {
        "type": "object",
        "required": [
          "expires_at",
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "expires_at": {
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "behavior": {
            "default": "upsert",
            "$ref": "#/components/schemas/OperationBehavior"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "OperationBehavior": {
        "type": "string",
        "enum": [
          "upsert",
          "insert",
          "update"
        ]
      },
      "KvSetOut": {
        "type": "object"
      },
      "KvGetIn": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        }
      },
      "KvGetOut": {
        "type": "object",
        "required": [
          "expires_at",
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "expires_at": {
            "description": "Time of expiry",
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          },
          "value": {
            "type": "string"
          }
        }
      },
      "KvDeleteIn": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          }
        }
      },
      "KvDeleteOut": {
        "type": "object",
        "required": [
          "deleted"
        ],
        "properties": {
          "deleted": {
            "type": "boolean"
          }
        }
      },
      "RateLimiterConfigureIn": {
        "type": "object",
        "required": [
          "capacity",
          "key",
          "refill_amount",
          "refill_interval_seconds"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "capacity": {
            "description": "Maximum capacity of the bucket",
            "type": "integer",
            "format": "uint64",
            "minimum": 1.0
          },
          "refill_amount": {
            "description": "Number of tokens to add per refill interval",
            "type": "integer",
            "format": "uint64",
            "minimum": 1.0
          },
          "refill_interval_seconds": {
            "description": "Interval in seconds between refills (minimum 1 second)",
            "type": "integer",
            "format": "uint64",
            "minimum": 1.0
          }
        }
      },
      "RateLimiterConfigureOut": {
        "type": "object"
      },
      "RateLimiterCheckIn": {
        "type": "object",
        "required": [
          "key"
        ],
        "properties": {
          "key": {
            "type": "string",
            "maxLength": 256,
            "pattern": "^[a-zA-Z0-9\\-_.]+$",
            "example": "some_key"
          },
          "tokens_requested": {
            "description": "Number of tokens to consume (default: 1)",
            "default": 1,
            "type": "integer",
            "format": "uint64",
            "minimum": 0.0
          }
        }
      },
