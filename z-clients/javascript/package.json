{
  "name": "coyote",
  "version": "1.85.0",
  "repository": "https://github.com/svix/coyote",
  "type": "module",
  "keywords": [
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "pack": "tsdown --sourcemap",
    "prepublishOnly": "npm run build && npm run pack",
    "check": "biome check",
    "check:fix": "biome check --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --fix",
    "fmt": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "msgpackr": "^1.11.9"
  }
}
