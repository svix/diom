{
  "name": "diom",
  "version": "1.85.0",
  "description": "Diom JavaScript client library",
  "author": "Svix Inc. <oss@svix.com>",
  "repository": "https://github.com/svix/diom",
  "type": "module",
  "keywords": [
    "diom",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "tsdown",
    "prepublishOnly": "npm run build && npm run bundle",
    "check": "biome check",
    "check:fix": "biome check --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --fix",
    "fmt": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "msgpackr": "^1.11.9",
    "temporal-polyfill-lite": "^0.3.3"
  }
}
